# n8n deploy env — VARIABLE NAMES ONLY. Set real values as Dokploy secrets; never commit literals.
# Copy to Dokploy's Environment tab. (.env itself is gitignored — this .example is the template.)

# Image tag — latest stable n8n release; same tag exists for n8n + runners.
N8N_VERSION=2.27.4

# Postgres superuser + database (created on first init).
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=n8n

# Least-privilege user n8n actually connects as (created by init-data.sh).
POSTGRES_NON_ROOT_USER=
POSTGRES_NON_ROOT_PASSWORD=

# Shared secret between the n8n broker and the task runner.
RUNNERS_AUTH_TOKEN=

# CRITICAL — encrypts stored credentials. Generate once, store as a secret, set before first boot.
N8N_ENCRYPTION_KEY=

# Schedule/cron correctness (also mapped to TZ).
GENERIC_TIMEZONE=Asia/Vientiane
